# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and should never be committed.
#
# All variables are validated at build time by src/env.ts (zod + @t3-oss/env-nextjs).
# Adding a new env var? Register it there first or the build will fail.

# -----------------------------------------------------------------------------
# GraphQL endpoint
# Optional in local dev — the Apollo client defaults to /api/graphql (relative).
# Required in production / cross-origin deployments.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/api/graphql
