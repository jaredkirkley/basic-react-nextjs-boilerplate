{
  "name": "basic-react-nextjs-boilerplate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "c8 tsx --tsconfig tsconfig.test.json --test src/__tests__/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=html tsx --tsconfig tsconfig.test.json --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.11.0",
    "@apollo/server": "^4.0.0",
    "@as-integrations/next": "^3.0.0",
    "graphql": "^16.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "c8": "^10.0.0",
    "eslint": "^8.0.0",
    "eslint-config-airbnb": "^19.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
